{
  "name": "kasi-lunar",
  "version": "1.0.3",
  "description": "한국천문연구원(KASI) 기준 음양력 변환 TypeScript Library (-59~2050년 지원)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate:data": "node scripts/generate-early-data.mjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check": "tsc --noEmit",
    "harness:smoke": "bun run build && node scripts/codex-smoke.cjs",
    "harness:report": "node scripts/codex-report.cjs",
    "test": "bun run build && node scripts/verify-build.mjs",
    "test:sample-full": "bun run build && node scripts/verify-sample-full.mjs",
    "test:all": "bun run check && bun run harness:smoke && bun run test && bun run test:sample-full",
    "prepublishOnly": "bun run check && bun run test"
  },
  "keywords": [
    "lunar",
    "calendar",
    "kasi",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "korean-lunar-calendar": "^0.3.6",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
