{
  "name": "kasi-lunar",
  "version": "0.8.1",
  "description": "TypeScript lunar calendar library aligned to the KASI supported conversion range.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate:data": "node scripts/generate-early-data.mjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check": "tsc --noEmit",
    "harness:smoke": "npm run build && node scripts/codex-smoke.cjs",
    "harness:report": "node scripts/codex-report.cjs",
    "test": "npm run build && node scripts/verify-build.mjs",
    "prepublishOnly": "npm run check && npm run test"
  },
  "keywords": [
    "lunar",
    "calendar",
    "kasi",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "korean-lunar-calendar": "^0.3.6",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
